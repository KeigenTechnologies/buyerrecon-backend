DATABASE_URL=postgres://user:pass@localhost:5432/br_collector
PORT=3000
ALLOWED_ORIGINS=https://buyerrecon.com,https://www.buyerrecon.com,https://keigen.co.uk,https://www.keigen.co.uk,https://fidcern.com,https://www.fidcern.com,https://realbuyergrowth.com,https://www.realbuyergrowth.com,https://timetopoint.com,https://www.timetopoint.com,http://localhost:8000,http://127.0.0.1:8000
PROBE_ENCRYPTION_KEY=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
# Sprint 1 PR#4: pepper for HMAC-SHA256(site_write_token, pepper).
# Held in env / secrets manager only — NEVER stored in DB. Loss of the pepper
# requires re-issuing every site write token. Read by §3.PR#5 collector wiring.
SITE_WRITE_TOKEN_PEPPER=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# Sprint 1 PR#7: pepper for HMAC-SHA256 IP anonymisation (ipHash).
# Held in env / secrets manager only — NEVER stored in DB. Distinct from
# SITE_WRITE_TOKEN_PEPPER (different security purpose: auth lookup vs IP
# anonymisation). Loss of this pepper makes existing ip_hash values
# uncorrelatable with future ones but is otherwise safe — no token re-issue.
IP_HASH_PEPPER=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# Sprint 1 PR#7: /v1/batch endpoint feature flag (handoff Decision #1).
# Defaults to false. /v1/event is always available. /v1/batch returns
# HTTP 404 { error: "v1_batch_disabled" } unless this is set to literal 'true'.
ENABLE_V1_BATCH=false

# Sprint 1 PR#7: per-server opt-in for consent_state_summary in canonical_jsonb.
# Defaults to false (deny-by-default per the PR#5b-2 consent narrow fix).
# Set to literal 'true' to opt in; any other value is treated as false.
ALLOW_CONSENT_STATE_SUMMARY=false

COLLECTOR_VERSION=1.0.0

# Sprint 1 PR#8: real DB verification suite ONLY (opt-in via npm run test:db:v1).
# Local or staging test DB only. NEVER production. Must NOT equal DATABASE_URL.
# Loaded only by tests/v1/db/_setup.ts; never by runtime app code.
TEST_DATABASE_URL=postgres://user:pass@localhost:5432/br_collector_test
